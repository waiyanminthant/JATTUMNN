{
  "manifest_version": 3,
  "name": "JATTUMNN",
  "version": "0.1",
  "description": "Just Another Translate Tool U Might Not Need",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "translate-text": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Translate hovered text"
    }
  },
  "options_ui": {
    "page": "ui/settings.html",
    "open_in_tab": true
  }
}