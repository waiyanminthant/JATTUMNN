{
  "manifest_version": 3,
  "name": "JATTUMNN",
  "version": "0.2.0",
  "description": "Just Another Translate Tool U Might Not Need",
  "permissions": ["activeTab", "storage"],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js", 
        "modules/*.js", 
        "ui/*.css",
        "ui/*.html",
        "ui/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["modules/contentLoader.js"]
    }
  ],
  "commands": {
    "translate-text": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Translate hovered text"
    },
    "translate-input": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Open translation modal"
    }
  },
  "options_ui": {
    "page": "ui/settings.html",
    "open_in_tab": true
  }
}